{
  "expo": {
    "name": "Cardyn",
    "slug": "cardflex",
    "version": "1.2.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cardyn",
    "userInterfaceStyle": "light",
    "statusBar": {
      "backgroundColor": "#F5F6FA",
      "style": "dark",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D1F24"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardyn.app",
      "buildNumber": "14",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:cardyn.net",
        "webcredentials:cardyn.net"
      ],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Cardyn to access your photos to upload gift card images.",
        "NSCameraUsageDescription": "Allow Cardyn to take photos of your gift cards and scan card codes.",
        "NSFaceIDUsageDescription": "Allow Cardyn to use Face ID for secure biometric login.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.47948483945-4c5ohnnrrrnl72a9lc06rn1o6rqb7lu3"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D1F24"
      },
      "package": "com.cardyn.app",
      "versionCode": 13,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cardyn.net",
              "pathPrefix": "/ref"
            },
            {
              "scheme": "https",
              "host": "cardyn.net",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "98a1c75e-abef-4a2d-b8c1-1bb67c162440"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1F24",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0D1F24"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00C2B4",
          "sounds": [],
          "mode": "production"
        }
      ],
      "expo-apple-authentication"
    ],
    "owner": "tuka21",
    "runtimeVersion": "1.2.0",
    "updates": {
      "url": "https://u.expo.dev/98a1c75e-abef-4a2d-b8c1-1bb67c162440",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
